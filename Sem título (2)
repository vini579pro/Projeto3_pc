from carregar_dados import carregar_jogos
from filabacklog import filabacklog
from pilharecentes import PilhasRecentes

print("Testando carregamento de dados...")
jogos = carregar_jogos()
print(f"✓ {len(jogos)} jogos carregados")

if jogos:
    print(f"  Primeiro jogo: {jogos[0].titulo} ({jogos[0].console})")
    print(f"  Ultimo jogo: {jogos[-1].titulo} ({jogos[-1].console})")

print("\nTestando FilaBacklog...")
backlog = filabacklog()
for jogo in jogos[:3]:
    backlog.enqueue(jogo)
print(f"✓ FilaBacklog com {backlog.tamanho()} jogos")

print("\nTestando PilhasRecentes...")
recentes = PilhasRecentes()
jogo_teste = jogos[0]
recentes.push(jogo_teste)
print(f"✓ PilhasRecentes com {recentes.tamanho()} jogo(s)")
top = recentes.topo()
if top:
    print(f"  Topo: {top.titulo}")

print("\n✓ Todos os testes passaram")
